#!/bin/ksh

###
### Environmental parameters for Cadence 6.1
### --Created for ECE 126 GWU
### --Modified for ESE 578 Upenn
### --Includes ENV parameters for NCSU 1.6.0 Beta Kit
###

## export CDSROOT=/mnt/pollux/software/ic-design/cadence
export CDSROOT=/lcars/software/linux/x86_64/ic-design/cadence
export CDS_LIC_FILE=1711@head.hep.upenn.edu
export LM_LICENSE_FILE=$CDS_LIC_FILE
export OA_UNSUPPORTED_PLAT="linux_rhel60"
export W3264_NO_HOST_CHECK=1
#export CDS_AUTO_64BIT=ALL

###
### Cadence 6.1 Environmental variables
###
export CDSDIR=$CDSROOT/IC618
export SKIP_CDS_DIALOG=TRUE
CADPATH=.:$CDSDIR/tools/bin:$CDSDIR/tools/dfII/bin

###
### Cadence IUS (simvision, verilog-XL, nc-verilog)
### Cadence SOC (encounter)
###
CADPATH=$CDSROOT/ius/tools/bin:$CDSROOT/ius/tools/dfII/bin:$CADPATH
CADPATH=$CDSROOT/soc/tools/bin:$CDSROOT/soc/tools/dfII/bin:$CADPATH
CADPATH=$CDSROOT/ets/tools/bin:$CDSROOT/ets/tools/dfII/bin:$CADPATH
###
### Cadence Assura Environmental variables
###
export ASSURAHOME=$CDSROOT/assura
export SUBSTRATESTORMHOME=$ASSURAHOME
export LANG=C
CADPATH=$ASSURAHOME/tools/bin:$ASSURAHOME/tools/assura/bin:$SUBSTRATESTORMHOME/bin:$CADPATH

###
### Cadence MMSIM (Simulation Tools) variables
###
export MMSIMHOME=$CDSROOT/MMSIM71
export CDS_rfExamples='cds_root icms'
export CDS_Netlisting_Mode="Analog"
CADPATH=$MMSIMHOME/tools/bin:$MMSIMHOME/tools/dfII/bin:$CADPATH
# mmsim must come before cadence in path, for new virtuoso spectre RF to run

###
### Cadence's EXT QRC Tool Environmental variables
###
export EXTHOME=$CDSROOT/ext
export QRC_ENABLE_EXTRACTION=t
CADPATH=$EXTHOME/tools/bin:$EXTHOME/tools/dfII/bin:$CADPATH

###
### Cadence Encounter Conformal
###
export CONFRML=$CDSROOT/conform
CADPATH=$CONFRML/tools/bin:$CONFRML/tools/dfII/bin:$CADPATH

###
### NON-Cadence products are below, used in ECE 126
###

###
### NCSU Cadence Design Kit Environmental Variable
###
#export DESIGNKITS=/mnt/pollux/software/cadence
#export CDK_DIR=$DESIGNKITS/PDK/ncsu-cdk-1.6.0.beta
export DESIGNKITS=~ese5780/design_kits
export CDK_DIR=$DESIGNKITS/ncsu-cdk-1.6.0.beta
export CDS_SITE=$CDK_DIR  # uses NCSU .cdsenv
export USE_NCSU_CDK=TRUE
export SYSTEM_CDS_LIB_DIR=/

###
### IIT Standard Cells Environmental Variable
###
export OSU_DIR=$DESIGNKITS/osu_stdcells_v2p7

###
### Sonnet/Cadence Interface
###
export SONNET_DIR=/usr/local/sonnet

###
### export PATH only once
###
export PATH=$CADPATH:$PATH
export CDS_AHDLCMI_ENABLE=NO
